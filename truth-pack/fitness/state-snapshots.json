{
  "stateSnapshots": [
    {
      "type": "athlete_readiness_state",
      "inspectableFields": ["memberId", "readinessScore", "fatigueScore", "capturedAt"],
      "freshnessSlaSeconds": 300,
      "derivedFrom": ["recent completed session durations", "consecutive misses", "active streak days"]
    },
    {
      "type": "weekly_progress_state",
      "inspectableFields": [
        "memberId",
        "weekStartDate",
        "plannedWorkoutCount",
        "completedWorkoutCount",
        "capturedAt"
      ],
      "freshnessSlaSeconds": 300,
      "derivedFrom": ["active routine non-rest day count", "current week completed sessions"]
    },
    {
      "type": "streak_health_state",
      "inspectableFields": ["memberId", "activeStreakDays", "lastCompletedDate", "streakAtRisk", "capturedAt"],
      "freshnessSlaSeconds": 300,
      "derivedFrom": ["14-day completed session history", "consecutive misses"]
    }
  ]
}
