{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://playbook.local/schemas/playbook-status.schema.json",
  "title": "Playbook Status Artifact",
  "type": "object",
  "required": [
    "version",
    "generatedAt",
    "engine",
    "repo",
    "knowledge",
    "contracts",
    "recommendation"
  ],
  "properties": {
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "engine": {
      "type": "object",
      "required": ["name", "version", "commit", "statusSchemaVersion"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "commit": { "type": "string" },
        "statusSchemaVersion": { "type": "string", "pattern": "^\\d+\\.\\d+$" }
      },
      "additionalProperties": true
    },
    "repo": {
      "type": "object",
      "required": ["root"],
      "properties": {
        "root": { "type": "string" },
        "name": { "type": "string" }
      },
      "additionalProperties": true
    },
    "knowledge": {
      "type": "object",
      "required": ["draft", "proposed", "promoted"],
      "properties": {
        "draft": {
          "type": "object",
          "required": ["count"],
          "properties": { "count": { "type": "integer", "minimum": 0 } },
          "additionalProperties": true
        },
        "proposed": {
          "type": "object",
          "required": ["count"],
          "properties": { "count": { "type": "integer", "minimum": 0 } },
          "additionalProperties": true
        },
        "promoted": {
          "type": "object",
          "required": ["count"],
          "properties": { "count": { "type": "integer", "minimum": 0 } },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "contracts": {
      "type": "object",
      "required": ["summary", "byContract"],
      "properties": {
        "summary": {
          "type": "object",
          "required": ["pass", "warn", "fail"],
          "properties": {
            "pass": { "type": "integer", "minimum": 0 },
            "warn": { "type": "integer", "minimum": 0 },
            "fail": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": true
        },
        "byContract": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "status", "violations"],
            "properties": {
              "id": { "type": "string" },
              "status": { "type": "string", "enum": ["pass", "warn", "fail"] },
              "violations": { "type": "integer", "minimum": 0 }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "recommendation": {
      "type": "object",
      "required": ["nextCommand", "reason", "suggestedWhen"],
      "properties": {
        "nextCommand": { "type": "string" },
        "reason": { "type": "string" },
        "suggestedWhen": {
          "type": "string",
          "enum": ["now", "before_pr", "before_merge"]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
